## Turso (create a NEW demo database — must be separate from any production instance)
TURSO_DATABASE_URL=libsql://your-demo-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=<your_turso_auth_token>

## NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-string

## Cloudflare R2 (per-tenant logo uploads — S3-compatible object storage).
## OPTIONAL: if these are absent, the in-app logo UPLOAD control is disabled and
## a logo URL can still be set manually. The app builds and runs without R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
## Public base URL the bucket is served from (e.g. https://logos.tcdash.app or
## the R2 dev URL). Stored logo URLs are R2_PUBLIC_BASE_URL + '/' + objectKey.
R2_PUBLIC_BASE_URL=
